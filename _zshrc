export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
ZSH_THEME="${ZSH_THEME:-robbyrussell}"

HIST_STAMPS="yyyy-mm-dd"
plugins=(git)

export LANG="${LANG:-en_US.UTF-8}"
export EDITOR="${EDITOR:-vim}"
export SSH_KEY_PATH="${SSH_KEY_PATH:-$HOME/.ssh/id_rsa}"

case "$(uname -s)" in
  Darwin)
    DOTFILES_OS="macos"
    ;;
  Linux)
    DOTFILES_OS="linux"
    ;;
  *)
    DOTFILES_OS="other"
    ;;
esac
export DOTFILES_OS

# Keep PATH unique while allowing easy front/back insertion.
typeset -U path PATH
add_path_front() {
  [[ -d "$1" ]] && path=("$1" $path)
}
add_path_back() {
  [[ -d "$1" ]] && path+=("$1")
}
prune_missing_paths() {
  local dir expanded
  local -a cleaned
  for dir in "${path[@]}"; do
    expanded="${~dir}"
    [[ -n "$expanded" && -d "$expanded" ]] && cleaned+=("$expanded")
  done
  path=("${cleaned[@]}")
}
source_if_exists() {
  [[ -f "$1" ]] && source "$1"
}

# Common local tool paths.
add_path_front "$HOME/.local/bin"
add_path_front "$HOME/.antigravity/antigravity/bin"
add_path_front "$HOME/.gem/ruby/3.0.0/bin"
add_path_front "/usr/local/lib/ruby/gems/3.0.0/bin"
add_path_back "$HOME/bin"
add_path_back "$HOME/.cargo/bin"

if [[ "$DOTFILES_OS" == "macos" ]]; then
  add_path_front "/opt/homebrew/bin"
  add_path_front "/usr/local/texlive/2024/bin/universal-darwin"
  add_path_front "/Applications/Postgres.app/Contents/Versions/latest/bin"
  add_path_front "/usr/local/opt/python@3.9/bin"
  add_path_back "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
elif [[ "$DOTFILES_OS" == "linux" ]]; then
  add_path_front "/usr/local/sbin"
  add_path_back "/snap/bin"
fi

if [[ -d "$HOME/perl5" ]]; then
  add_path_front "$HOME/perl5/bin"
  export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
  export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}"
  export PERL_MB_OPT="--install_base \"$HOME/perl5\""
  export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5"
fi

[[ -r "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# Vim keybind.
bindkey -v
function zle-line-init zle-keymap-select {
  VIM_NORMAL="%K{208}%F{black}%k%f%K{208}%F{white} % NORMAL %k%f%K{black}%F{208}%k%f"
  VIM_INSERT="%K{075}%F{black}%k%f%K{075}%F{white} % INSERT %k%f%K{black}%F{075}%k%f"
  RPS1="${${KEYMAP/vicmd/$VIM_NORMAL}/(main|viins)/$VIM_INSERT}"
  RPS2=$RPS1
  zle reset-prompt
}
zle -N zle-line-init
zle -N zle-keymap-select

# Personal aliases.
alias m="make"
alias mc="make clean"
if [[ "$DOTFILES_OS" == "macos" ]]; then
  alias o="open"
elif command -v xdg-open >/dev/null 2>&1; then
  alias o="xdg-open"
fi
alias vps="globalprotect connect --portal mdr-vpn.ads.isi.edu"
alias vpsd="globalprotect disconnect"
alias python="python3"
alias pip="pip3"
alias codex="codex -m gpt-5.2-codex"

# Conda (only when installed).
for conda_root in "$HOME/anaconda3" "$HOME/opt/anaconda3" "$HOME/miniconda3"; do
  if [[ -x "$conda_root/bin/conda" ]]; then
    __conda_setup="$("$conda_root/bin/conda" 'shell.zsh' 'hook' 2> /dev/null)"
    if [[ $? -eq 0 ]]; then
      eval "$__conda_setup"
    elif [[ -f "$conda_root/etc/profile.d/conda.sh" ]]; then
      . "$conda_root/etc/profile.d/conda.sh"
    else
      add_path_front "$conda_root/bin"
    fi
    unset __conda_setup
    break
  fi
done

# opam configuration.
[[ -r "$HOME/.opam/opam-init/init.zsh" ]] && . "$HOME/.opam/opam-init/init.zsh" > /dev/null 2> /dev/null

# nvm with quick startup: avoid auto "nvm use" on every shell open.
export NVM_DIR="$HOME/.nvm"
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  . "$NVM_DIR/nvm.sh" --no-use
  [[ -s "$NVM_DIR/bash_completion" ]] && . "$NVM_DIR/bash_completion"

  autoload -U add-zsh-hook
  typeset -g __NVMRC_ACTIVE=0
  load-nvmrc() {
    local nvmrc_path
    nvmrc_path="$(nvm_find_nvmrc)"

    if [[ -n "$nvmrc_path" ]]; then
      local node_version nvmrc_node_version
      node_version="$(nvm version)"
      nvmrc_node_version="$(nvm version "$(cat "${nvmrc_path}")")"

      if [[ "$nvmrc_node_version" == "N/A" ]]; then
        nvm install
        __NVMRC_ACTIVE=1
      elif [[ "$nvmrc_node_version" != "$node_version" ]]; then
        nvm use
        __NVMRC_ACTIVE=1
      fi
    elif [[ "${__NVMRC_ACTIVE:-0}" -eq 1 ]]; then
      nvm use --silent default >/dev/null 2>&1
      __NVMRC_ACTIVE=0
    fi
  }
  add-zsh-hook chpwd load-nvmrc
  load-nvmrc
fi

source_if_exists "$HOME/google-cloud-sdk/path.zsh.inc"
source_if_exists "$HOME/google-cloud-sdk/completion.zsh.inc"
source_if_exists "$HOME/.ghcup/env"

# Machine-local overrides should stay untracked.
source_if_exists "$HOME/configs/myShellConfig.sh"
source_if_exists "$HOME/.config/shell/local.zsh"
source_if_exists "$HOME/.config/shell/local.${DOTFILES_OS}.zsh"
source_if_exists "$HOME/.config/shell/secrets.zsh"

# Drop stale PATH entries inherited from older shell configs.
prune_missing_paths

dump_zsh_state() {
  # Dump current zsh state for Cursor integration.
  echo "ZSH_VERSION=$ZSH_VERSION"
  echo "PWD=$PWD"
  echo "PATH=$PATH"
  echo "SHELL=$SHELL"
}
